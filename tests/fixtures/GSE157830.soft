!Sample_relation = SRA: https://www.ncbi.nlm.nih.gov/sra?term=SRX9106616
!Sample_supplementary_file_1 = ftp://ftp.ncbi.nlm.nih.gov/geo/samples/GSM4775nnn/GSM4775599/suppl/GSM4775599_Tu8902_shGOT1_plsdox_2.genes.txt.gz
!Sample_supplementary_file_2 = ftp://ftp.ncbi.nlm.nih.gov/geo/samples/GSM4775nnn/GSM4775599/suppl/GSM4775599_Tu8902_shGOT1_plsdox_2.isoforms.txt.gz
